  m_Script: {fileID: 11500000, guid: 266ee5624740d8b43b24e535e8e2b780, type: 3}
  m_Name: Tutorial-Wallbreak
  m_EditorClassIdentifier: 
  textLines:
  - text: Welcome to the wallbreak tutorial that will go over the basic functions.
  - text: Hold down R or left shoulder button to charge meter, once filled, release
      to dash and break down walls with the related symbol. Pickup star to proceed
  - text: The dash ability is also great for making it across gaps or other potential
      ground hazards. Pickup star to proceed
  - text: 'Complete tutorial by picking up final star '
  npcName: Narrator
