  m_Script: {fileID: 11500000, guid: 266ee5624740d8b43b24e535e8e2b780, type: 3}
  m_Name: Tutorial-NPC
  m_EditorClassIdentifier: 
  textLines:
  - text: 'Welcome to the NPC interactions tutorial

'
  - text: Walk up to the floating bubble and attack (Left mouse/right trigger) 3
      times to free the NPC
  - text: Once freed, talk to the NPC with either E key (keyboard) or X button (Controller)
  - text: After speaking with the NPC, they will appear back in town where you can
      purchase items, abilities, or upgrades
  - text: Speak to the NPC to finish the tutorial
  npcName: Narrator
